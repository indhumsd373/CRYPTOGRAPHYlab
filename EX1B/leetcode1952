import math

class Solution:
    def isThree(self, n: int) -> bool:
        # Step 1: Find the square root of n
        root = int(math.isqrt(n))
        
        # Step 2: Check if n is a perfect square and > 1
        if root * root != n or n < 4:
            return False
            
        # Step 3: Check if the root itself is a prime number
        # If the root is prime, n has exactly 3 divisors: 1, root, and n.
        for i in range(2, int(math.isqrt(root)) + 1):
            if root % i == 0:
                return False
                
        return True
